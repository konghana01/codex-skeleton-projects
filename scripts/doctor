#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
failures=0

ok() {
  printf 'ok      %s\n' "$1"
}

warn() {
  printf 'warn    %s\n' "$1"
}

fail() {
  printf 'missing %s\n' "$1"
  failures=$((failures + 1))
}

check_cmd_required() {
  local name="$1"
  if command -v "$name" >/dev/null 2>&1; then
    ok "command: $name"
  else
    fail "command: $name"
  fi
}

check_cmd_optional() {
  local name="$1"
  if command -v "$name" >/dev/null 2>&1; then
    ok "optional command: $name"
  else
    warn "optional command not found: $name"
  fi
}

check_path() {
  local path="$1"
  if [ -e "$ROOT_DIR/$path" ]; then
    ok "path: $path"
  else
    fail "path: $path"
  fi
}

echo "Side Harness doctor"
echo "Root: $ROOT_DIR"
echo

check_cmd_required bash
check_cmd_required git
check_cmd_optional node
check_cmd_optional npm
check_cmd_optional pnpm
check_cmd_optional python3

echo
check_path README.md
check_path AGENTS.md
check_path docs
check_path docs/project-start.md
check_path docs/rules-and-skills.md
check_path docs/skill-authoring.md
check_path docs/github.md
check_path projects/registry.md
check_path prompts
check_path prompts/start-project.md
check_path prompts/create-skill.md
check_path scripts/new-project
check_path templates/scratch/README.md
check_path templates/scratch/AGENTS.md
check_path templates/scratch/.env.example
check_path templates/scratch/.gitignore
check_path templates/scratch/src
check_path templates/scratch/tests

echo
echo "Templates:"
find "$ROOT_DIR/templates" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort | sed 's/^/  - /'

echo
if [ "$failures" -gt 0 ]; then
  echo "Doctor found $failures missing required item(s)."
  exit 1
fi

echo "Doctor passed."
